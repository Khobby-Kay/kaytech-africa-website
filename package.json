{
  "name": "kaytech-africa",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next dev",
    "build": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && node scripts/rename-images.mjs && next build",
    "start": "next start",
    "lint": "next lint",
    "blur": "node scripts/generate-blur.mjs",
    "compress": "node scripts/compress-images.mjs",
    "rename-images": "node scripts/rename-images.mjs",
    "brand-assets": "node scripts/generate-brand-assets.mjs"
  },
  "dependencies": {
    "lucide-react": "^1.18.0",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "sharp": "^0.35.1",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
