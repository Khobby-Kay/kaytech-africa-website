# Copy this file to .env.local (local dev) and add the same vars in Vercel.
# Every var is optional — the site runs fine without them, features light up
# automatically once a value is present.

# Google Analytics 4 measurement ID (analytics.google.com -> Admin -> Data Streams)
NEXT_PUBLIC_GA_ID=

# Google Search Console verification token (Search Console -> Settings ->
# Ownership verification -> HTML tag -> copy only the content="..." value)
GOOGLE_SITE_VERIFICATION=

# Lead email delivery via Resend (resend.com). When set, the contact form
# emails new leads to LEAD_INBOX. Without it, the form falls back to WhatsApp.
RESEND_API_KEY=
LEAD_INBOX=info@kaytechafrica.com
LEAD_FROM=KayTech Africa <info@kaytechafrica.com>

# Optional: power the on-site AI assistant with a live LLM. Without a key, the
# assistant still answers from the built-in KayTech knowledge base.
OPENAI_API_KEY=
